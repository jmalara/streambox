<advancedsettings>
  <!-- Cache settings are configured in Kodi GUI since Omega (v21):      -->
  <!-- Settings → Services → Caching (set level to Expert)               -->
  <!--   Buffer mode: 1 (all filesystems)                                -->
  <!--   Memory size: 350 MB (safe for 4GB RAM devices)                  -->
  <!--   Read factor: 20 (aggressive pre-buffering)                      -->
  <!-- The <cache> XML tags are IGNORED in Kodi 21+ and have no effect.  -->
  <network>
    <curlclienttimeout>30</curlclienttimeout>
    <curllowspeedtime>30</curllowspeedtime>
    <curlretries>3</curlretries>
    <disableipv6>true</disableipv6>
  </network>
  <gui>
    <algorithmdirtyregions>3</algorithmdirtyregions>
  </gui>
</advancedsettings>
